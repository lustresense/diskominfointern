# ============================================
# SIMRP - Environment Variables Template
# Salin file ini menjadi .env.local dan isi nilainya
# JANGAN commit .env.local ke Git
# ============================================

# --- Frontend (Vite) ---
# URL base untuk backend API lokal
VITE_API_BASE_URL=http://127.0.0.1:8000/make-server-32aa5c5c

# --- Backend Python (server/) ---

# Environment: development | production
SIMRP_ENV=development

# Path ke database SQLite (opsional, ada default)
# SIMRP_DB_PATH=./database/runtime/database.db

# PBKDF2 iterations untuk hashing password
# SIMRP_PBKDF2_ITERATIONS=210000

# Session TTL dalam jam (default: 168 jam dev, 24 jam prod)
# SIMRP_SESSION_TTL_HOURS=168

# Origins yang diizinkan (pisahkan dengan koma, untuk production)
# SIMRP_ALLOWED_ORIGINS=https://yourdomain.com

# Admin login credentials (untuk /auth/admin-login, production only)
# SIMRP_ADMIN_LOGIN_USERNAME=admin
# SIMRP_ADMIN_LOGIN_PASSWORD=ganti_dengan_password_kuat

# Password awal untuk seed admin account
# SIMRP_SEED_ADMIN_PASSWORD=admin

# Rate limiting
# SIMRP_RATE_LIMIT_WINDOW_SECONDS=60
# SIMRP_RATE_LIMIT_AUTH_MAX=10
# SIMRP_RATE_LIMIT_MUTATION_MAX=120
